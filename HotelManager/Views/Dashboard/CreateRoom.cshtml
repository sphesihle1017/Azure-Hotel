@model Room
@{
    ViewData["Title"] = "Create Room";
    Layout = "_Layout";
    ViewBag.HideFooter = true;
}

<div class="container mt-4">
    <h1 class="mb-4">Create New Room</h1>

    <!-- Add this to display any TempData messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Room Details</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CreateRoom" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="HotelId" class="control-label fw-bold">Hotel</label>
                            <select asp-for="HotelId" class="form-control" asp-items="@(new SelectList(ViewBag.Hotels, "HotelId", "Name"))" required>
                                <option value="">-- Select Hotel --</option>
                            </select>
                            <span asp-validation-for="HotelId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="RoomDescription" class="control-label fw-bold">Room Type</label>
                            <select asp-for="RoomDescription" class="form-control" required>
                                <option value="">-- Select Room Type --</option>
                                <option value="Deluxe">Deluxe</option>
                                <option value="Premium">Premium</option>
                                <option value="Presidential">Presidential</option>
                            </select>
                            <span asp-validation-for="RoomDescription" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PricePerNight" class="control-label fw-bold">Price Per Night (R)</label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input asp-for="PricePerNight" class="form-control" type="number" step="0.01" min="1" required />
                            </div>
                            <span asp-validation-for="PricePerNight" class="text-danger"></span>
                            <small class="text-muted">Enter price in Rand (e.g., 1500.00)</small>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Create Room
                            </button>
                            <a asp-action="Rooms" class="btn btn-secondary">
                                <i class="bi bi-x"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    footer {
        display: none !important;
    }

    .input-group-text {
        background-color: #1a3c40;
        color: white;
        border: none;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Ensure decimal values are handled correctly
            $('#PricePerNight').on('blur', function() {
                var value = $(this).val();
                if (value && !isNaN(value)) {
                    // Format to 2 decimal places
                    $(this).val(parseFloat(value).toFixed(2));
                }
            });

            // Log form submission for debugging
            $('form').on('submit', function() {
                console.log('Form submitted');
                console.log('HotelId: ' + $('#HotelId').val());
                console.log('RoomDescription: ' + $('#RoomDescription').val());
                console.log('PricePerNight: ' + $('#PricePerNight').val());
            });
        });
    </script>
}